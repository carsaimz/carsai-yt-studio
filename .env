# Variáveis de build (publishable / públicas) — opcional para self-host.
# Tudo aqui é embutido no bundle (não use para segredos privados).

# === Hosting ===
# Hosting preset para `bun run build` (node-server | static | vercel | netlify | cloudflare-pages)
NITRO_PRESET=node-server

# === Atualizações ===
# Repositório GitHub usado para checar novas releases
VITE_UPDATE_REPO=carsaimz/carsai-yt-studio

# === Firebase (gerenciado pelo desenvolvedor) ===
# Estas chaves são PUBLISHABLE (pretendidas para o cliente Firebase).
# Configure-as ao buildar para uma instância. Em self-host, deixe vazio e o
# wizard manual permitirá colar a config no app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=