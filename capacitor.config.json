{
  "appId": "com.carsai.ytstudio",
  "appName": "Carsai YT Studio",
  "webDir": "dist/client",
  "appVersion": "0.1.0",
  "appVersionCode": 1,
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 800,
      "backgroundColor": "#1a1410",
      "launchAutoHide": true,
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1a1410",
      "overlaysWebView": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Preferences": {
      "group": "CarsaiSecureStore"
    }
  }
}
